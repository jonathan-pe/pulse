{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "types": [
      "node"
    ],
    "resolveJsonModule": true,
    "paths": {
      "@pulse/*": [
        "../*/src"
      ],
      "@pulse/db": [
        "../db/src"
      ],
      "@pulse/db/*": [
        "../db/*"
      ],
      "@pulse/graphql/*": [
        "../graphql/*"
      ],
      "@pulse/ui/*": [
        "../ui/*"
      ]
    }
  }
}