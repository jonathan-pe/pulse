// game.prisma — Game, GameOdds, Result

model Game {
  id       String   @id @default(cuid())
  league   String
  startsAt DateTime

  // Team relations (foreign keys)
  homeTeamId String
  homeTeam   Team   @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId String
  awayTeam   Team   @relation("AwayTeam", fields: [awayTeamId], references: [id])

  status String @default("scheduled")

  odds        GameOdds[]
  predictions Prediction[]
  result      Result?

  @@index([league, startsAt])
  @@index([homeTeamId])
  @@index([awayTeamId])
}

model GameOdds {
  id            String  @id @default(cuid())
  gameId        String
  game          Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  provider      String
  market        String?
  book          String?
  moneylineHome Int?
  moneylineAway Int?
  spread        Float?
  total         Float?

  updatedAt DateTime @default(now())

  @@unique([gameId, book, market])
  @@index([gameId, provider])
}

model Result {
  id        String   @id @default(cuid())
  gameId    String   @unique
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  homeScore Int
  awayScore Int
  settledAt DateTime @default(now())
}
