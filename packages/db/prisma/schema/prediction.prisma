// prediction.prisma — Prediction enum + model

enum PredictionType {
  MONEYLINE
  SPREAD
  TOTAL
}

model Prediction {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameId    String
  game      Game           @relation(fields: [gameId], references: [id], onDelete: Cascade)
  type      PredictionType
  pick      String
  createdAt DateTime       @default(now())
  lockedAt  DateTime?

  // Scoring metadata
  oddsAtPrediction Json? // Snapshot of odds when prediction was made
  bonusTier        Boolean   @default(false) // True if this was in first 5 daily predictions
  processedAt      DateTime? // When scoring was calculated
  isCorrect        Boolean? // Result of prediction (null = not yet scored)

  // Bonus tier is determined at prediction creation time based on daily order (first 5 = bonus)
  // This prevents client-side abuse and centralizes business logic
  // Allow multiple predictions per game, but not duplicate type+pick combinations
  @@unique([userId, gameId, type, pick])
  @@index([userId, createdAt]) // For daily ordering
  @@index([userId, gameId])
}
