generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Optional: Only needed for connection pooling (e.g., Supabase, PgBouncer)
  // For local dev, this can be omitted from your .env file
  // directUrl = env("DIRECT_URL")
}
