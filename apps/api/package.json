{
  "name": "@pulse/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/router.d.ts",
  "exports": {
    ".": {
      "types": "./dist/router.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "pnpm run build:bundle && pnpm run build:types",
    "build:bundle": "tsup",
  "build:types": "tsc -p tsconfig.json",
    "start": "NODE_ENV=production node --enable-source-maps --unhandled-rejections=strict dist/index.js"
  },
  "dependencies": {
    "@clerk/express": "^1.7.24",
    "@pulse/types": "workspace:*",
    "@trpc/server": "^11.5.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "zod": "^4.0.17",
    "@pulse/db": "workspace:*"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "tsup": "^6.6.0",
    "ts-node": "^10.9.1",
    "tsx": "^3.12.7"
  }
}
