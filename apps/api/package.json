{
  "name": "@pulse/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch --clear-screen=false --ignore 'dist/**' --ignore '**/*.test.ts' src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "prebuild": "pnpm db:generate && pnpm --filter @pulse/types build && pnpm --filter @pulse/shared build",
    "build": "tsup",
    "start": "NODE_ENV=production node dist/index.js",
    "ingest": "tsx src/cli/ingest.ts",
    "ingest-historical": "tsx src/cli/ingest-historical.ts",
    "sync-teams": "tsx src/cli/sync-teams.ts",
    "score-games": "tsx src/cli/score-games.ts"
  },
  "dependencies": {
    "@clerk/express": "^1.7.24",
    "@pulse/shared": "workspace:*",
    "@prisma/adapter-pg": "^7.0.1",
    "@prisma/client": "^7.0.1",
    "@pulse/types": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "pg": "^8.13.1",
    "winston": "^3.18.3",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.3",
    "prisma": "^7.0.1",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.1",
    "tsup": "^8.5.0"
  }
}
