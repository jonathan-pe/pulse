// user.prisma — User-related models

model User {
  // Use Clerk user id as the primary key
  id          String   @id
  email       String   @unique
  username    String? // Unique identifier, used in URLs and mentions
  displayName String? // Optional display name (shows instead of username if set)
  imageUrl    String? // Profile picture URL from Clerk
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  // Point scoring streak tracking (bonus tier only)
  currentStreak Int @default(0)
  longestStreak Int @default(0) // All-time best streak for achievements

  predictions      Prediction[]
  ledger           PointsLedger[]
  userAchievements UserAchievement[]
}

model PointsLedger {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  delta     Int
  reason    String
  meta      Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}
