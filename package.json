{
  "name": "pulse",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "version": "0.1.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "concurrently -n api,web,marketing -c blue,green,yellow \"pnpm dev:api\" \"pnpm dev:web\" \"pnpm dev:marketing\"",
    "dev:api": "pnpm --filter @pulse/api dev",
    "dev:web": "pnpm --filter @pulse/web dev",
    "dev:marketing": "pnpm --filter @pulse/marketing dev",
    "db:generate": "pnpm --filter @pulse/api db:generate",
    "db:migrate": "pnpm --filter @pulse/api db:migrate",
    "db:studio": "pnpm --filter @pulse/api db:studio",
    "db:seed": "pnpm --filter @pulse/api db:seed",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "db:reset": "docker-compose down -v && docker-compose up -d",
    "lint": "eslint .",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "test:watch": "pnpm -r run test:watch",
    "clean": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' + && find . -name 'dist' -type d -prune -exec rm -f '{}' +"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/jest": "^29.5.5",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2",
    "vitest": "^1.3.0"
  }
}
