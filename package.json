{
  "name": "pulse",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "version": "0.1.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:api": "pnpm --filter @pulse/api dev",
    "dev:web": "pnpm --filter @pulse/web dev",
    "dev": "concurrently -n api,web -c blue,green \"pnpm dev:api\" \"pnpm dev:web\"",
    "lint": "eslint ."
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "eslint": "^9.5.0",
    "typescript": "^5.5.4"
  }
}