{
  "name": "pulse",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "version": "0.1.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:marketing": "pnpm --filter @pulse/marketing dev",
    "dev:api": "pnpm --filter @pulse/api dev",
    "dev:web": "pnpm --filter @pulse/web dev",
    "db:generate": "pnpm -F @pulse/db generate",
    "db:migrate": "pnpm -F @pulse/db migrate",
    "db:studio": "pnpm -F @pulse/db studio",
    "db:seed": "pnpm -F @pulse/db seed",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "db:reset": "docker-compose down -v && docker-compose up -d",
    "dev": "concurrently -n api,web,marketing -c blue,green,yellow \"pnpm dev:api\" \"pnpm dev:web\" \"pnpm dev:marketing\"",
    "clean": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' + && find . -name 'dist' -type d -prune -exec rm -f '{}' + && find . -name '*.tsbuildinfo' -type f -prune -exec rm -f '{}' +",
    "lint": "eslint .",
    "typecheck": "pnpm -r -w exec tsc --noEmit",
    "update-deps": "pnpm -r up --latest",
    "update-and-verify": "pnpm run update-deps && pnpm -r -w install && pnpm -r build && pnpm -r -w run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/jest": "^29.5.5",
    "@types/node": "^24.3.0",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2",
    "vitest": "^1.3.0"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.85.6",
    "@trpc/client": "^11.5.0",
    "@trpc/server": "^11.5.0",
    "@trpc/tanstack-react-query": "^11.5.0"
  }
}
